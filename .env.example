# JWT signing key - change to a random string in production
SECRET_KEY=change-me-to-a-random-string

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-password-here

# Database
DATABASE_URL=sqlite:///./data/data.db

# Upload directory
UPLOAD_DIR=./uploads

# Initial max upload size (can be changed via admin panel)
MAX_UPLOAD_SIZE_BYTES=104857600
